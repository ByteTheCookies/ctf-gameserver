# Optional vpnstatus profile configuration.
# Enable with: docker compose --profile vpnstatus up -d vpnstatus

# Uncomment and adjust checks you want to run.
# CTF_GATEWAY_IPPATTERN=10.66.%s.1
# CTF_DEMO_IPPATTERN=10.66.%s.3
# CTF_DEMO_SERVICEPORT=80
# CTF_VULNBOX_IPPATTERN=10.66.%s.2
# CTF_VULNBOX_SERVICEPORT=80

# WireGuard checks require `wg` and appropriate privileges in the container.
# CTF_WIREGUARD_IFPATTERN=wg%d
