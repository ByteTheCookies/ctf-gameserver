# Checker config for service slug "ccforms-2".
# In SCORING -> Services, create a service with slug exactly "ccforms-2".

CTF_SERVICE=ccforms-2
CTF_CHECKERSCRIPT=/app/checkers/CCForms-2/checker.py

# Total checker masters for this service across all hosts/containers.
CTF_CHECKERCOUNT=1

CTF_INTERVAL=30
CTF_IPPATTERN=10.60.%s.1
