# Checker config for service slug "vulnify-1".
# In SCORING -> Services, create a service with slug exactly "vulnify-1".

CTF_SERVICE=vulnify-1
CTF_CHECKERSCRIPT=/app/checkers/vulnify-1/checker.py

# Total checker masters for this service across all hosts/containers.
CTF_CHECKERCOUNT=1

CTF_INTERVAL=30
CTF_IPPATTERN=10.60.%s.1
