# Checker config for service slug "pwn".
# In SCORING -> Services, create a service with slug exactly "pwn".

CTF_SERVICE=pwn
CTF_CHECKERSCRIPT=/app/examples/checker/example_checker.py

# Total checker masters for this service across all hosts/containers.
# Update when scaling checker_pwn instances.
CTF_CHECKERCOUNT=1

CTF_INTERVAL=10
CTF_IPPATTERN=10.66.%s.2
