# Checker config for service slug "cake-configurator".
# In SCORING -> Services, create a service with slug exactly "cake-configurator".

CTF_SERVICE=cake-configurator
CTF_CHECKERSCRIPT=/app/checkers/cake-configurator/checker.py

# Total checker masters for this service across all hosts/containers.
CTF_CHECKERCOUNT=1

CTF_INTERVAL=30
CTF_IPPATTERN=10.60.%s.1
