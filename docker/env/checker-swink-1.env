# Checker config for service slug "swink-1".
# In SCORING -> Services, create a service with slug exactly "swink-1".

CTF_SERVICE=swink-1
CTF_CHECKERSCRIPT=/app/checkers/swink-1/checker.py

# Total checker masters for this service across all hosts/containers.
CTF_CHECKERCOUNT=1

CTF_INTERVAL=30
CTF_IPPATTERN=10.60.%s.1
