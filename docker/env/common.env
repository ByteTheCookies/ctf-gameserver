# Shared defaults for all CTF Gameserver components.
# Override any of these through your shell environment or a local .env file.

CTF_LOGLEVEL=INFO

# Shared flag settings for checker/submission.
# Replace this secret before running a real competition.
CTF_FLAGSECRET=RFVNTVlTRUNSRVQ=

# Submission: extract team net number from client source IP.
# This default matches net ranges like "10.66.<team_net_no>.x".
CTF_TEAMREGEX=^10\.81\.(\d+)\.\d+$

# Web settings (docker/web-settings/prod_settings.py)
DJANGO_SECRET_KEY=change-me-before-production
DJANGO_ALLOWED_HOSTS=*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_TIME_ZONE=UTC
